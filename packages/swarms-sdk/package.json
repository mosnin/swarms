{
  "name": "@swarms/sdk",
  "version": "0.2.0",
  "description": "TypeScript client SDK for Swarms — the on-demand execution layer that autonomous AI agents call to spawn sandboxed worker agents.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "zod": "^3.24.1"
  }
}
