# Hermes Cloud — environment template.
# Copy to .env.local for development. NEVER commit real secrets.

# Runtime
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
APP_BASE_URL=http://localhost:3000

# Postgres (system of record) — required.
DATABASE_URL=postgres://hermes:hermes@localhost:5432/hermes

# LOCAL DEV ADAPTER: dashboard session fallback user (dev only)
DEV_AUTH_USER_EMAIL=demo@hermes.cloud
# Optional API key hashing pepper (HMAC); >= 16 chars
# API_KEY_PEPPER=
