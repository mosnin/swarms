# Swarms — environment template.
# Copy to .env.local for development. NEVER commit real secrets.

# Runtime
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
APP_BASE_URL=http://localhost:3000

# Postgres (system of record) — required.
DATABASE_URL=postgres://swarms:swarms@localhost:5432/swarms

# LOCAL DEV ADAPTER: dashboard session fallback user (dev only)
DEV_AUTH_USER_EMAIL=demo@swarms.cloud
# Optional API key hashing pepper (HMAC); >= 16 chars
# API_KEY_PEPPER=

# --- Agent compute -----------------------------------------------------------
# How spawned worker agents run:
#   mock       deterministic, offline (default; dev/test)
#   openrouter the OpenAI Agents SDK harness in-process (needs OPENROUTER_API_KEY)
#   modal      that same harness inside a Modal sandbox (production)
AGENT_RUNTIME=mock
AGENT_DEFAULT_MODEL=deepseek/deepseek-chat-v4

# OpenRouter (model provider) — required for AGENT_RUNTIME=openrouter.
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Modal worker (see infra/modal/README.md) — required for AGENT_RUNTIME=modal.
# MODAL_RUN_URL=https://<org>--swarms-agent-worker-fastapi-app.modal.run/run
# MODAL_TOKEN=<same value as the Modal secret SWARMS_WORKER_TOKEN>

# Compute pricing (integer minor units per metered second).
GPU_RATE_MINOR_PER_SECOND=2
GPU_RATE_CURRENCY=USD

# --- Secrets at rest ---------------------------------------------------------
# AES-256-GCM key (base64, 32 bytes) for encrypting resource bundles +
# connector secrets. Required in production. Generate: openssl rand -base64 32
# CONNECTOR_ENCRYPTION_KEY=

# --- Payments (x402) ---------------------------------------------------------
# mock for dev; x402 to settle on-chain. Pay-to address is never hardcoded.
X402_PROVIDER=mock
# X402_NETWORK=base-sepolia
# X402_PAY_TO_ADDRESS=
# X402_FACILITATOR_URL=
# X402_ASSET=

# --- Webhooks ----------------------------------------------------------------
# HMAC secret for signing outbound webhooks (>= 16 chars). Set in production.
# WEBHOOK_SIGNING_SECRET=

# --- Sessions & internal ------------------------------------------------------
# HMAC secret for signing human dashboard session cookies (>= 32 chars).
# Required in production. Generate: openssl rand -hex 32
# SESSION_SECRET=
# Shared secret the standalone worker sends on /api/internal/* (>= 32 chars).
# Required in production. Generate: openssl rand -hex 32
# INTERNAL_WORKER_SECRET=

# --- Human login (OAuth 2.0 / OIDC) ------------------------------------------
# Dashboard sign-in. Provider-agnostic authorization-code + PKCE flow — point it
# at any compliant IdP. "dev" uses the local email dev-login (disabled in prod);
# "oauth" uses the IdP below and is REQUIRED for a working production login.
#
# Clerk setup (see docs/CLERK_SETUP.md for the full runbook):
#   Create a Clerk OAuth application, then fill these from its credentials.
#   <clerk-domain> is your Frontend API host, e.g. clerk.your-app.com or
#   equal-ferret-42.clerk.accounts.dev for a Clerk development instance.
AUTH_MODE=dev
# AUTH_PROVIDER_LABEL=Clerk
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_AUTHORIZE_URL=https://<clerk-domain>/oauth/authorize
# OAUTH_TOKEN_URL=https://<clerk-domain>/oauth/token
# OAUTH_USERINFO_URL=https://<clerk-domain>/oauth/userinfo
# OAUTH_REDIRECT_URL=https://<your-prod-domain>/api/auth/callback
# OAUTH_SCOPES=openid email profile
